CompileFlags:
  # Point clangd to the compile_commands.json generated by PlatformIO/CMake.
  # This gives clangd the exact compiler flags (include paths, defines) used
  # during the actual build, eliminating all false-positive "file not found"
  # errors for ESP-IDF and project headers like core1_engine.h, esp_err.h, etc.
  CompilationDatabase: .pio/build/esp32dev
